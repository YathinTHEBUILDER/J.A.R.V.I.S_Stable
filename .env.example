# Rename this file to .env and fill in your API keys

# Required for all modes
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# Optional: Add multiple Groq API keys for automatic fallback in case of rate limits
# GROQ_API_KEY_2="YOUR_SECOND_GROQ_API_KEY"
# GROQ_API_KEY_3="YOUR_THIRD_GROQ_API_KEY"

# Optional: Required for 'Realtime' chat mode
TAVILY_API_KEY="YOUR_TAVILY_API_KEY"
